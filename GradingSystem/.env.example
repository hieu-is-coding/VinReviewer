# ============================================================
#  Agentic Academic-Writing Reviewer — Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# LLM Provider (OpenAI-compatible)
# ------------------------------------------------------------

# OpenAI API key — required for all LLM calls
OPENAI_API_KEY=sk-...

# Model used for rubric building, keyword extraction, claim
# classification, and review synthesis (default: gpt-4o-mini).
OPENAI_MODEL=gpt-4o-mini

# Optional: Azure OpenAI endpoint / deployment overrides.
# Leave blank to use the standard OpenAI endpoint.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_DEPLOYMENT=

# ------------------------------------------------------------
# Semantic Scholar (literature retrieval)
# ------------------------------------------------------------

# Optional API key — unauthenticated requests are rate-limited
# to ~100 req/5 min; a key raises this significantly.
# Register at: https://www.semanticscholar.org/product/api
S2_API_KEY=

# ------------------------------------------------------------
# GROBID (PDF → TEI/XML)
# ------------------------------------------------------------

# URL of a running GROBID server (local Docker or remote).
# Default: http://localhost:8070
# Docker: docker run -p 8070:8070 lfoppiano/grobid:0.8.0
GROBID_URL=http://localhost:8070
# Connection & read timeout (in seconds) for GROBID requests. Default: 60
GROBID_TIMEOUT=60

# ------------------------------------------------------------
# LangSmith tracing (optional)
# ------------------------------------------------------------

# Enable LangChain/LangGraph tracing via LangSmith.
# Set LANGCHAIN_TRACING_V2=true to activate.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=agentic-reviewer

# ------------------------------------------------------------
# Pipeline behaviour
# ------------------------------------------------------------

# Maximum number of LLM regen attempts on red-line violations
# before flagging for human review (default: 1).
MAX_REGEN_ATTEMPTS=1

# Similarity threshold below which a citation is flagged as
# low-confidence by the evidence auditor (0.0–1.0, default: 0.3).
EVIDENCE_SIMILARITY_THRESHOLD=0.3

# Top-K papers retained after SPECTER2 reranking (default: 30).
LIT_POOL_TOP_K=30

# Huggingface access token
HF_TOKEN = hf_...