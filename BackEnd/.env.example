# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# GradingSystem LLM
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# GROBID (PDF parsing)
GROBID_URL=http://localhost:8070
GROBID_TIMEOUT=60

# Semantic Scholar (optional, for literature retrieval)
SEMANTIC_SCHOLAR_API_KEY=...
S2_API_KEY=...

CROSSREF_MAILTO=
OPENALEX_MAILTO=

# Server auth — clients must send this in X-API-Key header
API_KEY=change-me-in-production

# Concurrency limits
MAX_CONCURRENT_JOBS=5
JOB_TIMEOUT_SECONDS=600

# Redis (optional — leave blank to use in-memory queue)
REDIS_URL=